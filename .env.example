# Server Configuration
PORT=4040
NODE_ENV=development
SESSION_SECRET=your_secure_session_secret_here

# GitHub Configuration
GITHUB_APP_ID=your_github_app_id_here
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_CALLBACK_URL=http://localhost:4040/auth/github/callback

# GitHub App Background Auth (Private Key and Installation)
# Use \n for newlines in the private key if putting it in a single line env variable
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_INSTALLATION_ID=your_installation_id_here

# Optional: Default model to use if not specified
GITHUB_COPILOT_MODEL=gpt-4o

# Dremio Cloud Configuration
DREMIO_API_URL=https://api.dremio.cloud
DREMIO_TOKEN=your_dremio_token_here
DREMIO_PROJECT_ID=your_dremio_project_id_here

# News API Configuration
NEWS_API_KEY=your_news_api_key_here

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000
